# Neon Postgres — pooled URL for the app (serverless-friendly; hostname usually contains "-pooler")
DATABASE_URL=

# Neon Postgres — direct URL for Prisma CLI (migrations, db push; non-pooler hostname)
DIRECT_URL=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=

# Clerk webhooks — signing secret from Clerk Dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=

# Anthropic — Q&A feature
ANTHROPIC_API_KEY=
