// pgvector: enable the extension in Postgres before VECTOR columns exist.
// Declared on the datasource via `extensions = [vector]`; migrations also run
// `CREATE EXTENSION IF NOT EXISTS vector;` for providers (e.g. Neon) that require it.

generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(schema: "public")]
}

enum BookStatus {
  draft
  pending_review
  rejected
  published
  unlisted
  processing
}

/// Partner-visible choice stored when requesting review — admin aligns Publish vs Unlist with this hint.
enum ListingPreferenceAfterReview {
  published
  unlisted
}

enum BookGenre {
  fantasy
  horror
  romance
  adventure
  mystery
  science_fiction
  historical_fiction
  literary_fiction
  thriller
  childrens_fiction
  classic_literature
  gothic
  crime
  biography
  short_stories
}

enum AgeRange {
  EIGHTEEN_24
  TWENTY5_34
  THIRTY5_44
  FORTY5_54
  FIFTY5_PLUS
  UNDER_18
  PREFER_NOT_TO_SAY
}

enum Gender {
  male
  female
  non_binary
  other
  prefer_not_to_say
}

enum UserRole {
  reader
  partner
  admin
}

enum SpoilerProtection {
  INHERIT
  PROTECTED
  UNLOCKED
}

enum FeatureRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommentStatus {
  VISIBLE
  HIDDEN_SPOILER
  PENDING_CONTENT_REVIEW
  DELETED
}

enum NotificationType {
  COMMENT_HIDDEN_PENDING
  COMMENT_REINSTATED
  COMMENT_FLAGGED_FOR_MODERATION
  COMMENT_REPORTED_TO_AUTHOR
  COMMENT_FLAGGED_RESTORED
  COMMENT_FLAGGED_REMOVED
  COMMENT_RELEASED
  COMMENT_SPOILER_REMOVED
  COMMENT_SPOILER_CONFIRMED_GATED
  BOOK_APPROVED
  BOOK_REJECTED
  FEATURE_REQUEST_APPROVED
  FEATURE_REQUEST_REJECTED
}

enum PartnerApplicationStatus {
  pending
  approved
  rejected
}

enum SubscriptionTier {
  free
  standard
  premium
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
}

enum GrantType {
  TIER_UPGRADE
  QUERY_BONUS
  IMAGE_BONUS
}

enum GrantSource {
  ADMIN
  SYSTEM
  PURCHASE
}

enum CreditTransactionReason {
  PURCHASE
  SPEND_QUERY
  SPEND_IMAGE
  ADMIN_ADJUST
}

model Book {
  id                           String     @id @default(cuid())
  title                        String
  author                       String
  ownerId                      String?
  coverImageUrl                String?
  /// True when coverImageUrl is (or was set from) partner/admin Cover AI — used for gallery discover fallback rows.
  coverIsAiGenerated           Boolean    @default(false)
  description                  String?
  genre                        BookGenre?
  publishedYear                Int?
  openLibraryKey               String?
  gutenbergId                  Int?       @unique
  isPublicDomain               Boolean    @default(false)
  status                       BookStatus @default(draft)
  rejectionReason              String?
  /// Admin/partner-only reminders (not shown to readers).
  internalNotes                String?    @db.Text
  /// Set when submitting for admin review; cleared when review is withdrawn or resolved.
  listingPreferenceAfterReview ListingPreferenceAfterReview?
  scheduledPublishAt           DateTime?
  /// GPT genre-detection usage during EPUB ingest (OpenAI completion usage).
  ingestionPromptTokens     Int?
  ingestionCompletionTokens Int?
  /// Cumulative fal-based cover generations (partner quota path); increments per generation charge.
  coverGenAttemptsConsumed Int @default(0)
  /// Admin-editable allowance; partners cannot generate beyond granted minus consumed on quota path.
  coverGenAttemptsGranted  Int @default(5)

  featuredTargetAgeRanges String[] @default([])
  featuredTargetGenders   String[] @default([])
  featuredTargetCountries String[] @default([])
  featuredTargetGenres    String[] @default([])

  chapters        Chapter[]
  chunks          Chunk[]
  owner           User?        @relation("OwnedBooks", fields: [ownerId], references: [id])
  userBooks       UserBook[]
  readingProgress ReadingProgress[]
  queries         Query[]
  generatedImages      GeneratedImage[]
  coverAiQuotaRequests CoverAiQuotaRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([status])
}

/// Singleton rows (id "default"): admin prompts and allowed fal models JSON for publisher cover AI.
model CoverAiAdminSettings {
  id                   String @id
  basePromptPrefix     String @db.Text
  titlePromptTemplate  String @db.Text
  authorPromptTemplate String @db.Text
  modelsJson           Json

  updatedAt DateTime @updatedAt
}

/// Partner requests extra cover-generation allowance after hitting quota.
model CoverAiQuotaRequest {
  id          String    @id @default(cuid())
  bookId      String
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User      @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  handledAt   DateTime?

  @@index([bookId])
  @@index([bookId, handledAt])
}

model Chapter {
  id             String  @id @default(cuid())
  bookId         String
  sequenceNumber Int
  title          String?
  rawText        String  @db.Text

  book   Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  readingProgressAsCurrent ReadingProgress[] @relation("ReadingProgressCurrentChapter")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookId, sequenceNumber])
  @@index([bookId])
}

model Chunk {
  id             String                      @id @default(cuid())
  chapterId      String
  bookId         String
  sequenceNumber Int
  content        String                      @db.Text
  /// Embedding dimension 1536 (e.g. text-embedding-3-small / ada-002 class models). Query via raw SQL.
  embedding      Unsupported("vector(1536)")

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  book    Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, sequenceNumber])
  @@index([bookId])
  @@index([chapterId])
}

model User {
  id                      String    @id @default(cuid())
  clerkId                 String    @unique
  email                   String
  name                    String?
  username                String?   @unique
  gender                  Gender?
  subscribedToMailingList Boolean   @default(false)
  role                    UserRole  @default(reader)
  country                 String?
  ageRange                AgeRange?
  genrePreferences        String[]  @default([])
  /// When true (default), spoiler-style images are hidden until reading progress catches up unless overridden per book.
  globalSpoilerProtection Boolean            @default(true)
  subscriptionTier        SubscriptionTier   @default(free)
  subscriptionStatus      SubscriptionStatus @default(active)
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  usagePeriodAnchor       Int                @default(1)
  /// Authoritative billing period start for quota counting (Stripe period when subscribed).
  usagePeriodStart        DateTime?
  /// Grandfathered monthly limits — global tier decreases never reduce below these; increases still apply.
  queriesLimitFloor       Int?
  imagesLimitFloor        Int?
  /// When true, queries remain unlimited regardless of lowered global tier config.
  queriesUnlimitedFloor   Boolean            @default(false)

  userBooks       UserBook[]
  ownedBooks      Book[]    @relation("OwnedBooks")
  readingProgress ReadingProgress[]
  queries         Query[]
  generatedImages GeneratedImage[]
  likes           Like[]
  bookRequests    BookRequest[]
  featureRequests FeatureRequest[] @relation("FeatureRequests")
  featureReviews  FeatureRequest[] @relation("FeatureReviews")
  partnerApplications PartnerApplication[]
  partnerRequests     PartnerRequest[]
  comments            Comment[]
  notifications       Notification[]
  grants                 UserGrant[]
  badges                 UserBadge[]
  coverAiQuotaRequests   CoverAiQuotaRequest[]
  creditTransactions     CreditTransaction[]
  quotaOverrides         UserQuotaOverride[]
  aiServiceFailures      AiServiceFailure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One row per subscription tier — admin-editable limits and credit settings.
model TierLimitConfig {
  tier                   SubscriptionTier @id
  queriesPerMonth        Int?
  imagesPerMonth         Int?
  allowedModels          String[]         @default([])
  creditPurchasesEnabled Boolean          @default(false)
  creditCostQuery        Int              @default(1)
  creditCostImage        Int              @default(3)
  displayPriceMonthly    String?
  stripePriceId          String?
  updatedAt              DateTime         @updatedAt
  updatedBy              String?
}

/// Singleton row (id "singleton"): admin-tunable featured book scoring weights.
model FeaturedScoringConfig {
  id        String   @id @default("singleton")
  updatedAt DateTime @updatedAt
  updatedBy String?

  scoreGenrePrefMatch      Int @default(40)
  scoreLibraryDeep         Int @default(25)
  scoreLibraryStarted      Int @default(20)
  scoreLibraryRecentUnread Int @default(5)
  scoreLibraryStaleUnread  Int @default(2)
  libraryMatchCap          Int @default(3)
  libraryRecencyDays       Int @default(90)

  scoreRecencyFresh  Int @default(30)
  scoreRecencyRecent Int @default(15)
  scoreRecencyWarm   Int @default(5)
  recencyFreshDays   Int @default(7)
  recencyRecentDays  Int @default(30)
  recencyWarmDays    Int @default(90)

  scoreGenderMatch  Int @default(15)
  scoreAgeMatch     Int @default(12)
  scoreCountryMatch Int @default(8)

  penaltyGenderMismatch  Int @default(40)
  penaltyAgeMismatch     Int @default(30)
  penaltyCountryMismatch Int @default(15)

  minCarouselSlots Int @default(3)
}

/// Immutable snapshot each time admin saves featured scoring weights.
model FeaturedScoringHistory {
  id          String   @id @default(cuid())
  savedAt     DateTime @default(now())
  savedBy     String
  savedByName String

  scoreGenrePrefMatch      Int
  scoreLibraryDeep         Int
  scoreLibraryStarted      Int
  scoreLibraryRecentUnread Int
  scoreLibraryStaleUnread  Int
  libraryMatchCap          Int
  libraryRecencyDays       Int

  scoreRecencyFresh  Int
  scoreRecencyRecent Int
  scoreRecencyWarm   Int
  recencyFreshDays   Int
  recencyRecentDays  Int
  recencyWarmDays    Int

  scoreGenderMatch  Int
  scoreAgeMatch     Int
  scoreCountryMatch Int

  penaltyGenderMismatch  Int
  penaltyAgeMismatch     Int
  penaltyCountryMismatch Int

  minCarouselSlots Int

  @@index([savedAt])
}

/// Admin-configurable one-time credit packs (tier-priced).
model CreditPack {
  id              String   @id @default(cuid())
  name            String
  credits         Int
  active          Boolean  @default(true)
  priceFree       Int      @default(0)
  priceStandard   Int      @default(0)
  pricePremium    Int      @default(0)
  stripePriceId   String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions CreditTransaction[]
}

/// Immutable credit ledger — balance is sum of amounts per user.
model CreditTransaction {
  id                    String                  @id @default(cuid())
  userId                String
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount                Int
  reason                CreditTransactionReason
  bookId                String?
  creditPackId          String?
  creditPack            CreditPack?             @relation(fields: [creditPackId], references: [id], onDelete: SetNull)
  stripePaymentIntentId String?
  grantedBy             String?
  note                  String?
  createdAt             DateTime                @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([bookId])
}

/// Per-user quota limit override (takes precedence over tier defaults).
model UserQuotaOverride {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  queriesLimit  Int?
  imagesLimit   Int?
  expiresAt     DateTime?
  reason        String
  grantedBy     String
  createdAt     DateTime  @default(now())

  @@index([userId])
}

/// Logged when AI upstream fails — not deducted from quota.
model AiServiceFailure {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  route        String
  bookId       String?
  errorSummary String   @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model UserGrant {
  id                    String            @id @default(uuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantType             GrantType
  source                GrantSource       @default(ADMIN)
  tierValue             SubscriptionTier?
  bonusAmount           Int?
  usedAmount            Int               @default(0)
  startsAt              DateTime          @default(now())
  expiresAt             DateTime?
  reason                String?
  grantedBy             String
  stripePaymentIntentId String?
  createdAt             DateTime          @default(now())

  @@index([userId])
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey  String
  awardedAt DateTime @default(now())
  awardedBy String?
  note      String?

  @@unique([userId, badgeKey])
}

model PartnerRequest {
  id               String   @id @default(uuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  email            String
  accountUsername  String?
  pseudonym        String?
  publisherName    String?
  websiteUrl       String?
  catalogueNote    String   @db.Text
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PartnerApplication {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationName String
  contactEmail     String
  roleOrTitle      String?
  websiteUrl       String?
  catalogSummary   String @db.Text
  genresPublished  String @db.Text
  audienceReach    String?
  motivation       String @db.Text
  additionalNotes  String? @db.Text

  status PartnerApplicationStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model UserBook {
  id       String   @id @default(cuid())
  userId   String
  bookId   String
  addedAt  DateTime @default(now())
  isActive Boolean  @default(true)
  spoilerProtection SpoilerProtection @default(INHERIT)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
}

model ReadingProgress {
  id                   String @id @default(cuid())
  userId               String
  bookId               String
  currentChapterId     String
  currentChapterNumber Int

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  book           Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  currentChapter Chapter @relation("ReadingProgressCurrentChapter", fields: [currentChapterId], references: [id], onDelete: Restrict)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
  @@index([currentChapterId])
}

model Query {
  id                 String @id @default(cuid())
  userId             String
  bookId             String
  chapterNumberAtTime Int
  questionText       String @db.Text
  responseText       String @db.Text
  promptTokens         Int?
  completionTokens     Int?
  embeddingTokens      Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, bookId])
}

model GeneratedImage {
  id                  String  @id @default(cuid())
  userId              String
  bookId              String
  chapterNumberAtTime Int
  userPrompt          String  @db.Text
  fullPrompt          String  @db.Text
  imageUrl            String
  isPublic            Boolean @default(false)
  isFeatured          Boolean @default(false)
  likeCount           Int     @default(0)
  model               String?
  cfgScale            Float?
  seed                BigInt?
  steps               Int?
  width               Int?
  height              Int?
  sampler             String?
  negativePrompt      String? @db.Text
  rawParameters       Json?
  promptTokens        Int?
  completionTokens    Int?
  embeddingTokens     Int?
  subjectTokens         Int?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  book           Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  likes          Like[]
  featureRequest FeatureRequest?
  comments       Comment[]

  createdAt DateTime @default(now())

  @@index([userId, bookId])
  @@index([isPublic])
  @@index([isFeatured, isPublic])
}

model Comment {
  id        String        @id @default(uuid())
  imageId   String
  userId    String
  content   String        @db.VarChar(500)
  status           CommentStatus @default(VISIBLE)
  /** Dev/testing: raw spoiler-scan outcome from comment-scan (see lib/comment-spoiler-scan-debug.ts). */
  spoilerScanDebug     Json?
  /** Chapter used for spoiler gating (from scan or image chapter). */
  spoilerGateChapter     Int?
  /** Set when an admin confirms moderation (keep gated or acknowledge). */
  spoilerModerationAt    DateTime?
  createdAt            DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  image GeneratedImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@index([imageId, status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String           @db.Text
  link      String           @db.VarChar(2048)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model FeatureRequest {
  id           String               @id @default(cuid())
  imageId      String               @unique
  image        GeneratedImage       @relation(fields: [imageId], references: [id], onDelete: Cascade)
  requestedBy  String
  requester    User                 @relation("FeatureRequests", fields: [requestedBy], references: [id], onDelete: Cascade)
  status       FeatureRequestStatus @default(PENDING)
  reviewedBy   String?
  reviewer     User?                @relation("FeatureReviews", fields: [reviewedBy], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status])
  @@index([requestedBy])
}

model Like {
  id      String @id @default(cuid())
  userId  String
  imageId String

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  image GeneratedImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([imageId])
  @@unique([userId, imageId])
}

model BookRequest {
  id         String  @id @default(cuid())
  userId     String?
  bookTitle  String
  authorName String
  message    String? @db.Text

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bookTitle])
}
